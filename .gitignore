# ── Secrets (never commit) ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
credentials*.json

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# ── LaTeX build artefacts ────────────────────────────────────────────────────
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg

# ── Pipeline response cache (large, reproducible from JSONL) ─────────────────
Module_3_Intermediate_Report/code/runs/*/.cache/

# ── Sprint backups (keep on disk for rollback / forensic diff; do not commit) ─
*.pre_stats_refresh.bak
*.bak

# ── Sprint trash (rogue-session artifacts kept for forensics; do not commit) ──
.sprint_trash/

# ── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor noise ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Sprint archive (post-sprint orchestration scratch, local only) ──────────
.sprint_archive/
